# AWS Credentials (use dummy values for local development with LocalStack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# SNS Configuration
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:notification-events

# SQS Configuration
SQS_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/notification-queue

# LocalStack Endpoint (remove or leave empty for real AWS)
AWS_ENDPOINT_URL=http://localstack:4566
